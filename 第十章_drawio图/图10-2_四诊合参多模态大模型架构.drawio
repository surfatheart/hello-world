<mxfile host="app.diagrams.net" type="device">
  <diagram id="tcm-multimodal" name="图10-2 四诊合参多模态大模型架构">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="640" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="图10-2　四诊合参多模态大模型架构" style="text;html=1;align=center;fontSize=20;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1000" height="36" as="geometry" />
        </mxCell>

        <!-- 列标题 -->
        <mxCell id="h1" value="四诊输入" style="text;html=1;align=center;fontSize=13;fontStyle=1;fontColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="40" y="70" width="140" height="24" as="geometry" /></mxCell>
        <mxCell id="h2" value="模态编码器" style="text;html=1;align=center;fontSize=13;fontStyle=1;fontColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="230" y="70" width="150" height="24" as="geometry" /></mxCell>
        <mxCell id="h3" value="证候共享表示空间" style="text;html=1;align=center;fontSize=13;fontStyle=1;fontColor=#82b366;" vertex="1" parent="1"><mxGeometry x="430" y="70" width="160" height="24" as="geometry" /></mxCell>
        <mxCell id="h4" value="输出" style="text;html=1;align=center;fontSize=13;fontStyle=1;fontColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="650" y="70" width="150" height="24" as="geometry" /></mxCell>

        <!-- 输入 -->
        <mxCell id="i1" value="望诊·舌象（图像）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1"><mxGeometry x="40" y="110" width="140" height="50" as="geometry" /></mxCell>
        <mxCell id="i2" value="闻诊·语音/气味" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1"><mxGeometry x="40" y="190" width="140" height="50" as="geometry" /></mxCell>
        <mxCell id="i3" value="问诊·症状文本" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1"><mxGeometry x="40" y="270" width="140" height="50" as="geometry" /></mxCell>
        <mxCell id="i4" value="切诊·脉象波形" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1"><mxGeometry x="40" y="350" width="140" height="50" as="geometry" /></mxCell>

        <!-- 编码器 -->
        <mxCell id="e1" value="图像编码器" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1"><mxGeometry x="230" y="110" width="150" height="50" as="geometry" /></mxCell>
        <mxCell id="e2" value="语音/波形编码器" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1"><mxGeometry x="230" y="190" width="150" height="50" as="geometry" /></mxCell>
        <mxCell id="e3" value="文本编码器" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1"><mxGeometry x="230" y="270" width="150" height="50" as="geometry" /></mxCell>
        <mxCell id="e4" value="脉象编码器" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1"><mxGeometry x="230" y="350" width="150" height="50" as="geometry" /></mxCell>

        <!-- 共享表示空间 -->
        <mxCell id="shared" value="证候共享表示空间&#10;（跨模态融合）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="430" y="110" width="160" height="290" as="geometry" /></mxCell>

        <!-- 输出 -->
        <mxCell id="o1" value="证候预测" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1"><mxGeometry x="650" y="110" width="150" height="46" as="geometry" /></mxCell>
        <mxCell id="o2" value="辨证解释" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1"><mxGeometry x="650" y="184" width="150" height="46" as="geometry" /></mxCell>
        <mxCell id="o3" value="治法建议" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1"><mxGeometry x="650" y="258" width="150" height="46" as="geometry" /></mxCell>
        <mxCell id="o4" value="不确定性输出" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="1"><mxGeometry x="650" y="332" width="150" height="46" as="geometry" /></mxCell>

        <!-- 输入→编码器 -->
        <mxCell id="ie1" style="html=1;endArrow=block;strokeWidth=1.5;" edge="1" parent="1" source="i1" target="e1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ie2" style="html=1;endArrow=block;strokeWidth=1.5;" edge="1" parent="1" source="i2" target="e2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ie3" style="html=1;endArrow=block;strokeWidth=1.5;" edge="1" parent="1" source="i3" target="e3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ie4" style="html=1;endArrow=block;strokeWidth=1.5;" edge="1" parent="1" source="i4" target="e4"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- 编码器→共享空间 -->
        <mxCell id="es1" style="html=1;endArrow=block;strokeWidth=1.5;exitX=1;exitY=0.5;entryX=0;entryY=0.15;" edge="1" parent="1" source="e1" target="shared"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="es2" style="html=1;endArrow=block;strokeWidth=1.5;exitX=1;exitY=0.5;entryX=0;entryY=0.38;" edge="1" parent="1" source="e2" target="shared"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="es3" style="html=1;endArrow=block;strokeWidth=1.5;exitX=1;exitY=0.5;entryX=0;entryY=0.62;" edge="1" parent="1" source="e3" target="shared"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="es4" style="html=1;endArrow=block;strokeWidth=1.5;exitX=1;exitY=0.5;entryX=0;entryY=0.85;" edge="1" parent="1" source="e4" target="shared"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- 共享空间→输出 -->
        <mxCell id="so1" style="html=1;endArrow=block;strokeWidth=1.5;exitX=1;exitY=0.15;entryX=0;entryY=0.5;" edge="1" parent="1" source="shared" target="o1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="so2" style="html=1;endArrow=block;strokeWidth=1.5;exitX=1;exitY=0.38;entryX=0;entryY=0.5;" edge="1" parent="1" source="shared" target="o2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="so3" style="html=1;endArrow=block;strokeWidth=1.5;exitX=1;exitY=0.62;entryX=0;entryY=0.5;" edge="1" parent="1" source="shared" target="o3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="so4" style="html=1;endArrow=block;strokeWidth=1.5;exitX=1;exitY=0.85;entryX=0;entryY=0.5;" edge="1" parent="1" source="shared" target="o4"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- 底部质量控制带 -->
        <mxCell id="b1" value="数据质量控制" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="1"><mxGeometry x="80" y="470" width="200" height="50" as="geometry" /></mxCell>
        <mxCell id="b2" value="模态缺失提示" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="1"><mxGeometry x="350" y="470" width="200" height="50" as="geometry" /></mxCell>
        <mxCell id="b3" value="专家复核通道" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="1"><mxGeometry x="620" y="470" width="200" height="50" as="geometry" /></mxCell>
        <mxCell id="bb1" value="质控" style="html=1;endArrow=open;dashed=1;strokeColor=#d79b00;fontSize=10;" edge="1" parent="1" source="b1" target="e3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="bb2" value="缺失则降置信" style="html=1;endArrow=open;dashed=1;strokeColor=#d79b00;fontSize=10;" edge="1" parent="1" source="b2" target="shared"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="bb3" value="复核" style="html=1;endArrow=open;dashed=1;strokeColor=#d79b00;fontSize=10;" edge="1" parent="1" source="b3" target="o4"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="note" value="说明：多模态模型须同时输出预测结果与质量控制信息；模态缺失时给出置信度下降提示，而非生成虚假结论。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=left;spacingLeft=10;spacingRight=10;" vertex="1" parent="1"><mxGeometry x="80" y="550" width="740" height="50" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
